# Required management credential. Generate with: openssl rand -hex 32
DOCKER_CONTROL_TOKEN=replace-with-a-random-token

# If 16544 is occupied, 16545..16564 are tried.
DOCKER_CONTROL_LISTEN=0.0.0.0:16544
PORT_FALLBACKS=20
DOCKER_CONTROL_RUNTIME_FILE=./docker-control-runtime.json

# Default image. Trusted Bearer-authenticated management clients may override it per sandbox.
DOCKER_CONTROL_IMAGE=ubuntu:22.04
CONTAINER_NAME_PREFIX=sandbox
PULL_MISSING_IMAGE=true

# ws/wss URL reachable from managed sandboxes. {port} resolves after fallback.
DOCKER_CONTROL_PUBLIC_ENDPOINT=ws://host.docker.internal:{port}

ALLOW_NETWORK=true
SANDBOX_NETWORK=bridge
TERMINAL_IDLE_SECONDS=300
MAX_TERMINAL_WINDOWS=40
MAX_CONTAINERS=20
EXECUTION_TIMEOUT_SECONDS=120
